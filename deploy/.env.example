APP_NAME=MinIO Manager Web
BIND_ADDRESS=:8080
BASE_URL=http://localhost:8080
APP_MASTER_KEY=replace-with-a-very-long-random-string-at-least-32-chars
SQLITE_PATH=./data/minio-manager.db
FRONTEND_DIST_DIR=../frontend/dist
SESSION_TTL=8h
CONFIRMATION_TTL=5m
REQUEST_TIMEOUT=15s
ALLOW_ORIGIN=*

# If MinIOManagerWeb and MinIO are in the same docker-compose network,
# MINIO_ENDPOINT can be set to minio:9000
# Do not include http:// or https:// here.
MINIO_ENDPOINT=minio-api.example.com
MINIO_USE_SSL=true
MINIO_REGION=us-east-1

VITE_API_BASE_URL=
